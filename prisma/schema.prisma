model FacilityReservation {
  id                  String                    @id @default(uuid())
  userId              String
  user                User                      @relation(fields: [userId], references: [id])
  
  // Applicant Info
  applicantName       String
  organizationName    String?
  contactPerson       String
  contactNumber       String
  
  // Activity / Event Details
  activityType        FacilityActivityType
  activityTypeOther   String?
  description         String?
  
  // Facility & Schedule
  facilityType        FacilityType
  facilityDetails     String?
  desiredStartDate    DateTime
  desiredEndDate      DateTime
  estimatedParticipants Int
  
  // Optional uploads
  layoutFile          String?                   // Layout / equipment requirements
  governmentPermit    String?                   // Government permit / endorsement
  barangayEndorsement String?                   // Barangay endorsement
  additionalNotes     String?
  
  // Payment
  paymentStatus       PaymentType               @default(UNPAID)
  paymentMethod       String?
  paymentReference    String?
  paymentProof        String?
  amountDue           Float?
  amountPaid          Float?
  exemptionMemo       String?
  
  // Status & Processing
  status              FacilityReservationStatus  @default(PENDING_REVIEW)
  remarks             String?
  processedBy         String?
  processedAt         DateTime?
  
  // Gate Pass / Access
  gatePassCode        String?                   @unique
  gatePassUsed        Boolean                   @default(false)
  
  // Event Day Operations
  facilityDayStatus   FacilityDayStatus?
  markedCompletedAt   DateTime?
  noShow              Boolean                   @default(false)
  
