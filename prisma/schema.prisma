// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(uuid())
  email              String             @unique
  password           String
  name               String
  role               Role               @default(USER)
  mobile             String?
  birthdate          DateTime?
  address            String?
  houseNumber        String?
  street             String?
  barangay           String?
  profileComplete    Boolean            @default(false)
  resetToken         String?
  resetTokenExpiry   DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deathRegistrations DeathRegistration[]
  burialPermits      BurialPermit[]
  exhumationPermits  ExhumationPermit[]
  cremationPermits   CremationPermit[]
  deathCertificateRequests DeathCertificateRequest[]
  auditLogs          AuditLog[]
  transactions       Transaction[]
  notifications      Notification[]
  drainageRequests   DrainageRequest[]
  waterConnections   WaterConnection[]
  waterIssues        WaterIssue[]
  amenityReservations AmenityReservation[]
  venueBookings       VenueBooking[]
  maintenanceRequests ParkMaintenanceRequest[]
  facilityReservations FacilityReservation[]
}

enum Role {
  USER
  EMPLOYEE
  ADMIN
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  message     String
  type        String   // e.g., "death_registration", "burial_permit", etc.
  entityId    String?  // ID of related entity
  entityType  String?  // Type of related entity
  status      String?  // Status value from the entity
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String   // Descriptive name for the API key
  key         String   @unique
  isActive    Boolean  @default(true)
  createdBy   String   // Admin who created it
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  
  @@index([key])
}

model DeathRegistration {
  id                    String                    @id @default(uuid())
  userId                String
  user                  User                      @relation(fields: [userId], references: [id])
  
  // Registration Type
  registrationType      RegistrationType          @default(REGULAR)
  registrationFee       Float                     @default(50.00)
  
  // Deceased Details
  deceasedFirstName     String
  deceasedMiddleName    String?
  deceasedLastName      String
  deceasedDateOfBirth   DateTime
  deceasedDateOfDeath   DateTime
  deceasedPlaceOfDeath  String
  deceasedCauseOfDeath  String
  deceasedGender        String
  
  // Informant Details
  informantName         String
  informantRelation     String
  informantContactNumber String
  informantAddress      String
  
  // Document Uploads (file paths)
  municipalForm103      String  // Death Certificate Form
  informantValidId      String
  swabTestResult        String? // Optional, only if Covid-related
  
  // Delayed Registration Documents
  affidavitOfDelayed    String? // For delayed registration
  burialCertificate     String? // For delayed registration
  funeralCertificate    String? // For delayed registration
  psaNoRecord           String? // PSA Certificate of No Record
  
  // Payment Details
  orderOfPayment        String? // Generated OR number
  proofOfPayment        String? // Uploaded proof
  paymentConfirmed      Boolean                   @default(false)
  paymentStatus         String?                   @default("PENDING") // PENDING, PAID, FAILED
  
  // Status and Processing
  status                DeathRegistrationStatus   @default(PENDING_VERIFICATION)
  remarks               String?
  processedBy           String? // Employee ID who processed
  processedAt           DateTime?
  processingDeadline    DateTime? // For delayed: 11 working days from payment
  
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([registrationType])
  @@index([paymentStatus])
}

enum RegistrationType {
  REGULAR
  DELAYED
}

enum DeathRegistrationStatus {
  PENDING_VERIFICATION
  RETURNED_FOR_CORRECTION
  APPROVED_FOR_PAYMENT
  PAYMENT_SUBMITTED
  PAYMENT_CONFIRMED
  REGISTERED_FOR_PICKUP
  COMPLETED
  REJECTED
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String   // e.g., "DEATH_REGISTRATION_SUBMITTED", "DEATH_REGISTRATION_APPROVED"
  entityType  String   // e.g., "DeathRegistration", "User"
  entityId    String?  // ID of the affected entity
  details     String?  // JSON string with additional details
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}

model Transaction {
  id                String   @id @default(uuid())
  userId            String   // Citizen who paid
  user              User     @relation(fields: [userId], references: [id])
  transactionType   String   // e.g., "DEATH_REGISTRATION_FEE"
  amount            Float
  orderOfPayment    String   // OR number
  paymentMethod     String?  // e.g., "CASH", "ONLINE", "GCASH"
  referenceNumber   String?  // Reference from payment proof
  status            TransactionStatus @default(CONFIRMED)
  confirmedBy       String?  // Employee who confirmed
  confirmedAt       DateTime @default(now())
  entityType        String   // e.g., "DeathRegistration"
  entityId          String   // ID of related entity
  remarks           String?
  createdAt         DateTime @default(now())
  
  @@index([userId])
  @@index([status])
  @@index([transactionType])
  @@index([createdAt])
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

model BurialPermit {
  id                    String                @id @default(uuid())
  userId                String
  user                  User                  @relation(fields: [userId], references: [id])
  
  // Deceased Information
  deceasedName          String? // Deprecated: use separate name fields
  deceasedFirstName     String?
  deceasedMiddleName    String?
  deceasedLastName      String?
  deceasedSuffix        String?
  deceasedDateOfBirth   DateTime?
  deceasedDateOfDeath   DateTime
  deceasedGender        String?
  
  // Requester Information
  requesterName         String
  requesterRelation     String
  requesterContactNumber String
  requesterAddress      String
  
  // Burial Details
  burialType            BurialType            @default(BURIAL)
  nicheType             NicheType?            // Only for niche/columbarium
  cemeteryLocation      String?               // Bagbag, Novaliches, or other
  isFromAnotherLGU      Boolean               @default(false)
  
  // Document Uploads
  deathCertificate      String                // Path to death certificate
  transferPermit        String?               // If from another LGU
  affidavitOfUndertaking String?              // If Bagbag/Novaliches
  burialForm            String                // QCHD form
  validId               String                // Requester's ID
  
  // Payment and Processing
  orderOfPayment        String?
  permitFee             Float                 @default(100.00)
  nicheFee              Float?                // For niche: 750 (child) or 1500 (adult)
  totalFee              Float                 @default(100.00)
  proofOfPayment        String?
  paymentConfirmed      Boolean               @default(false)
  paymentStatus         String?               @default("PENDING") // PENDING, PAID, FAILED
  
  // Status and Processing
  status                BurialPermitStatus    @default(PENDING_VERIFICATION)
  remarks               String?
  processedBy           String?
  processedAt           DateTime?
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([burialType])
  @@index([paymentStatus])
}

enum BurialType {
  BURIAL           // Regular burial - ₱100
  ENTRANCE         // Entrance permit - ₱100  
  NICHE            // Niche/Columbarium - ₱100 + niche fee
}

enum NicheType {
  CHILD            // ₱750
  ADULT            // ₱1500
}

enum BurialPermitStatus {
  PENDING_VERIFICATION
  RETURNED_FOR_CORRECTION
  APPROVED_FOR_PAYMENT
  PAYMENT_SUBMITTED
  REGISTERED_FOR_PICKUP
  COMPLETED
  REJECTED
}
model DeathCertificateRequest {
  id                    String                         @id @default(uuid())
  userId                String
  user                  User                           @relation(fields: [userId], references: [id])
  
  // Deceased Information
  deceasedFullName      String
  deceasedDateOfDeath   DateTime
  deceasedPlaceOfDeath  String
  
  // Requester Information
  requesterName         String
  requesterRelation     String
  requesterContactNumber String
  requesterAddress      String
  purpose               String                         // Purpose of request
  
  // Certificate Details
  numberOfCopies        Int                            @default(1)
  pickupMethod          String                         @default("PICKUP_ONLY")  // Always pickup only
  
  // Document Uploads
  validId               String                         // Requester's ID
  authorizationLetter   String?                        // If not next of kin
  
  // Payment and Processing
  orderOfPayment        String?
  certificateFee        Float                          // ₱50 for first copy
  additionalCopiesFee   Float                          @default(0)  // ₱50 per additional copy
  totalFee              Float                          // Total amount
  submittedOrderNumber  String?                        // OR number submitted by user
  paymentProof          String?                        // Path to payment proof document
  paymentSubmittedAt    DateTime?
  paymentVerifiedBy     String?                        // Employee who verified payment
  paymentVerifiedAt     DateTime?
  paymentStatus         String?                        @default("PENDING") // PENDING, PAID, FAILED
  
  // Verification
  verifiedBy            String?                        // Employee who verified the request
  verifiedAt            DateTime?
  verificationNotes     String?
  
  // Certificate Processing
  certificatePrintedBy  String?                        // Employee who printed certificate
  certificatePrintedAt  DateTime?
  claimSchedule         String?                        // Scheduled date for pickup
  
  // Status and Processing
  status                DeathCertificateRequestStatus  @default(PENDING_VERIFICATION)
  remarks               String?
  processedBy           String?
  processedAt           DateTime?
  
  createdAt             DateTime                       @default(now())
  updatedAt             DateTime                       @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
}

enum DeathCertificateRequestStatus {
  PENDING_VERIFICATION
  RETURNED_FOR_CORRECTION
  APPROVED_FOR_PAYMENT
  PAYMENT_SUBMITTED
  REGISTERED_FOR_PICKUP
  COMPLETED
  REJECTED
}
model ExhumationPermit {
  id                    String                    @id @default(uuid())
  userId                String
  user                  User                      @relation(fields: [userId], references: [id])
  
  // Deceased Information (use separate name fields)
  deceasedName          String?                   // Deprecated: use separate name fields
  deceasedFirstName     String?
  deceasedMiddleName    String?
  deceasedLastName      String?
  deceasedSuffix        String?
  deceasedDateOfBirth   DateTime?
  deceasedDateOfDeath   DateTime
  deceasedGender        String?
  deceasedDateOfBurial  DateTime
  deceasedPlaceOfBurial String
  
  // Requester Information
  requesterName         String
  requesterRelation     String
  requesterContactNumber String
  requesterAddress      String
  reasonForExhumation   String
  
  // Document Uploads
  exhumationLetter      String                    // QC Health Dept letter
  deathCertificate      String                    // Certified death certificate
  validId               String                    // Requester's ID
  
  // Payment and Processing
  orderOfPayment        String?
  permitFee             Float                     @default(100.00)
  proofOfPayment        String?
  paymentConfirmed      Boolean                   @default(false)
  paymentStatus         String?                   @default("PENDING") // PENDING, PAID, FAILED
  
  // Status and Processing
  status                ExhumationPermitStatus    @default(PENDING_VERIFICATION)
  remarks               String?
  processedBy           String?
  processedAt           DateTime?
  
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
}

enum ExhumationPermitStatus {
  PENDING_VERIFICATION
  RETURNED_FOR_CORRECTION
  APPROVED_FOR_PAYMENT
  PAYMENT_SUBMITTED
  REGISTERED_FOR_PICKUP
  COMPLETED
  REJECTED
}
model CremationPermit {
  id                    String                    @id @default(uuid())
  userId                String
  user                  User                      @relation(fields: [userId], references: [id])
  
  // Deceased Information (use separate name fields)
  deceasedName          String?                   // Deprecated: use separate name fields
  deceasedFirstName     String?
  deceasedMiddleName    String?
  deceasedLastName      String?
  deceasedSuffix        String?
  deceasedDateOfBirth   DateTime?
  deceasedDateOfDeath   DateTime
  deceasedGender        String?
  
  // Requester Information
  requesterName         String
  requesterRelation     String
  requesterContactNumber String
  requesterAddress      String
  
  // Funeral Home (optional)
  funeralHomeName       String?
  funeralHomeContact    String?
  
  // Document Uploads
  deathCertificate      String                    // Path to death certificate
  cremationForm         String                    // QCHD cremation form
  transferPermit        String?                   // If from another location
  validId               String                    // Requester's ID
  
  // Payment and Processing
  orderOfPayment        String?
  permitFee             Float                     @default(100.00)
  submittedOrderNumber  String?                   // OR number submitted by user
  paymentProof          String?                   // Path to payment proof document
  paymentSubmittedAt    DateTime?
  paymentVerifiedBy     String?                   // Employee who verified payment
  paymentVerifiedAt     DateTime?
  paymentStatus         String?                   @default("PENDING") // PENDING, PAID, FAILED
  
  // Verification
  verifiedBy            String?                   // Employee who verified the documents
  verifiedAt            DateTime?
  verificationNotes     String?
  
  // Status and Processing
  status                CremationPermitStatus     @default(PENDING_VERIFICATION)
  remarks               String?
  processedBy           String?
  processedAt           DateTime?
  
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([paymentStatus])
}

enum CremationPermitStatus {
  PENDING_VERIFICATION
  RETURNED_FOR_CORRECTION
  APPROVED_FOR_PAYMENT
  PAYMENT_SUBMITTED
  REGISTERED_FOR_PICKUP
  COMPLETED
  REJECTED
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  eventDate   DateTime
  location    String
  category    EventCategory @default(OTHER)
  createdBy   String   // Employee/Admin who created the event
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([eventDate])
  @@index([category])
}

enum EventCategory {
  MEMORIAL
  ALL_SOULS
  UNDAS
  MAINTENANCE
  OTHER
}

// ============================================================================
// CEMETERY AND PLOT MANAGEMENT
// ============================================================================

model Cemetery {
  id             String   @id @default(uuid())
  name           String
  location       String
  totalPlots     Int      @default(0)
  availablePlots Int      @default(0)
  occupiedPlots  Int      @default(0)
  sections       Int      @default(0)
  coordinates    Json?    // GeoJSON polygon coordinates
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  plots          Plot[]
  
  @@index([active])
}

model Plot {
  id            String     @id @default(uuid())
  plotNumber    String
  plotType      PlotType   @default(LAWN)
  status        PlotStatus @default(AVAILABLE)
  cemeteryId    String
  cemetery      Cemetery   @relation(fields: [cemeteryId], references: [id])
  sectionId     String?
  sectionName   String?
  coordinates   Json?      // GeoJSON point or polygon
  totalLayers   Int        @default(3)
  occupiedLayers Int       @default(0)
  availableLayers Json?    // Array of available layer numbers [1,2,3]
  burialCount   Int        @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  burials       Burial[]
  
  @@unique([cemeteryId, plotNumber])
  @@index([status])
  @@index([cemeteryId])
}

enum PlotType {
  LAWN
  FAMILY
  MAUSOLEUM
  NICHE
  COLUMBARIUM
}

enum PlotStatus {
  AVAILABLE
  PARTIALLY_OCCUPIED
  FULLY_OCCUPIED
  RESERVED
  MAINTENANCE
}

model Burial {
  id                String   @id @default(uuid())
  plotId            String
  plot              Plot     @relation(fields: [plotId], references: [id])
  deceasedFirstName String
  deceasedMiddleName String?
  deceasedLastName  String
  deceasedSuffix    String?
  dateOfBirth       DateTime?
  dateOfDeath       DateTime
  dateOfBurial      DateTime?
  gender            String?
  layer             Int      @default(1) // 1-3
  relationship      String?  // To other burials in family plot
  notes             String?
  permitId          String?  // Link to pending permit if from external system
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([plotId])
  @@index([permitId])
}

// ============================================================================
// CEMETERY SYSTEM INTEGRATION (PAFM-C)
// ============================================================================

model CemeteryPermitSubmission {
  id                     String                @id @default(uuid())
  permitId               String                @unique // Our internal permit ID (from BurialPermit/ExhumationPermit)
  permitType             PermitSubmissionType  @default(BURIAL)
  status                 CemeterySubmissionStatus @default(PENDING_SUBMISSION)
  
  // Deceased Information (cached for display)
  deceasedFirstName      String
  deceasedMiddleName     String?
  deceasedLastName       String
  deceasedSuffix         String?
  dateOfBirth            DateTime?
  dateOfDeath            DateTime
  gender                 String?
  
  // Applicant Information
  applicantName          String
  applicantEmail         String?
  applicantPhone         String?
  relationshipToDeceased String?
  
  // Plot Preferences (from applicant)
  preferredCemeteryId    String?
  preferredPlotId        String?
  preferredSection       String?
  preferredLayer         Int?
  
  // Permit Details
  permitApprovedAt       DateTime
  permitExpiryDate       DateTime?
  permitDocumentUrl      String?
  
  // Submission to Cemetery System
  submittedToCemeteryAt  DateTime?
  cemeterySystemId       String?       // ID returned by PAFM-C
  
  // Assignment Details (from PAFM-C response)
  assignedPlotNumber     String?
  assignedCemetery       String?
  assignedCemeteryName   String?
  assignedAt             DateTime?
  assignedBy             String?       // Cemetery admin who assigned
  cemeteryBurialId       String?       // Burial ID in PAFM-C system
  
  // Rejection Details (from PAFM-C)
  rejectionReason        String?
  rejectedAt             DateTime?
  rejectedBy             String?
  
  // Sync/Error Tracking
  lastSyncAttempt        DateTime?
  syncError              String?
  retryCount             Int            @default(0)
  
  // Additional Data
  metadata               Json?
  notes                  String?
  
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  
  @@index([status])
  @@index([permitType])
  @@index([createdAt])
  @@index([submittedToCemeteryAt])
}

enum PermitSubmissionType {
  BURIAL
  EXHUMATION
}

enum CemeterySubmissionStatus {
  PENDING_SUBMISSION      // Approved here, not yet sent to cemetery
  SUBMITTED               // Sent to PAFM-C, awaiting assignment
  ASSIGNED                // Cemetery assigned plot
  REJECTED                // Cemetery rejected
  SYNC_ERROR              // Error communicating with cemetery system
}

// ============================================================================
// WATER SUPPLY & DRAINAGE SERVICES
// ============================================================================

model DrainageRequest {
  id                    String                @id @default(uuid())
  userId                String
  user                  User                  @relation(fields: [userId], references: [id])
  
  // Requester Information
  requesterName         String
  contactNumber         String
  
  // Location Details
  street                String
  barangay              String
  exactLocation         String?               // Additional location details / landmark
  
  // Request Details
  issueType             DrainageIssueType     @default(DECLOGGING)
  description           String?
  urgency               DrainageUrgency       @default(NORMAL)
  
  // Photos (optional)
  photo1                String?
  photo2                String?
  photo3                String?
  
  // Assignment
  assignedTo            String?               // Employee ID (District Engineer)
  assignedAt            DateTime?
  
  // Inspection
  inspectionDate        DateTime?
  inspectionNotes       String?
  inspectionPhotos      String?               // JSON array of photo paths
  programOfWorks        String?               // Uploaded document
  
  // Materials
  materialsStatus       String?               // AVAILABLE, NOT_AVAILABLE, NOT_NEEDED
  materialsNotes        String?
  
  // Work Completion
  workReport            String?
  beforePhoto           String?
  afterPhoto            String?
  completedAt           DateTime?
  completedBy           String?               // Employee who completed
  
  // Feedback
  citizenFeedback       String?
  citizenRating         Int?                  // 1-5 star rating
  
  // Status and Processing
  status                DrainageRequestStatus @default(PENDING_REVIEW)
  remarks               String?
  processedBy           String?
  processedAt           DateTime?
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([barangay])
  @@index([issueType])
  @@index([createdAt])
}

enum DrainageIssueType {
  DECLOGGING
  DESILTING
  MANHOLE_REPAIR
  GUTTER_MAINTENANCE
  INLET_MAINTENANCE
  FLOODING
  OTHER
}

enum DrainageUrgency {
  LOW
  NORMAL
  HIGH
  EMERGENCY
}

enum DrainageRequestStatus {
  PENDING_REVIEW
  INSPECTION_SCHEDULED
  INSPECTION_COMPLETED
  FOR_APPROVAL
  APPROVED_WITH_MATERIALS
  PENDING_NO_MATERIALS
  FOR_IMPLEMENTATION
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model WaterConnection {
  id                    String                    @id @default(uuid())
  userId                String
  user                  User                      @relation(fields: [userId], references: [id])
  
  // Applicant Information
  applicantName         String
  contactNumber         String
  
  // Installation Address
  houseNumber           String?
  street                String
  barangay              String
  landmark              String?
  
  // Structure Type
  structureType         StructureType             @default(RESIDENTIAL)
  
  // Document Uploads
  validId               String                    // Government ID
  propertyProof         String                    // Proof of property possession
  propertyProofType     String?                   // Type of proof uploaded
  
  // Inspection
  assignedInspector     String?                   // Employee ID
  inspectionDate        DateTime?
  mainlineAvailable     Boolean?
  tappingPointAvailable Boolean?
  pipeDistance           Float?                    // Distance in meters
  estimatedMaterials    String?                   // JSON or text description
  inspectionNotes       String?
  inspectionPhotos      String?                   // Photo path
  
  // Payment
  pipeSize              String?                   // e.g., "13mm", "20mm", etc.
  connectionFee         Float?                    // Based on pipe size
  paymentType           String?                   // FULL or INSTALLMENT (for 13mm)
  orNumber              String?                   // Official Receipt Number (entered by cashier)
  paymentConfirmedBy    String?                   // Cashier employee ID
  paymentConfirmedAt    DateTime?
  
  // Installation
  assignedTeam          String?                   // Installation team
  installationDate      DateTime?
  installationStatus    String?                   // SCHEDULED, ONGOING, COMPLETED
  installationNotes     String?
  
  // Status and Processing
  status                WaterConnectionStatus     @default(PENDING_EVALUATION)
  remarks               String?
  processedBy           String?
  processedAt           DateTime?
  
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([barangay])
  @@index([createdAt])
}

enum StructureType {
  RESIDENTIAL
  APARTMENT_TOWNHOUSE
  COMMERCIAL
  SCHOOL_CHURCH_OTHERS
}

enum WaterConnectionStatus {
  PENDING_EVALUATION
  RETURNED_INCOMPLETE
  FOR_INSPECTION
  FOR_BILLING
  AWAITING_PAYMENT
  PAYMENT_CONFIRMED
  INSTALLATION_SCHEDULED
  INSTALLATION_ONGOING
  ACTIVE_CONNECTION
  REJECTED
}

model WaterIssue {
  id                    String                @id @default(uuid())
  userId                String
  user                  User                  @relation(fields: [userId], references: [id])
  
  // Reporter Information
  reporterName          String
  address               String
  contactNumber         String
  
  // Issue Details
  issueType             WaterIssueType        @default(NO_WATER)
  description           String?
  
  // Photos (optional)
  photo1                String?
  photo2                String?
  photo3                String?
  
  // Assignment & Inspection
  assignedTo            String?               // Maintenance team / Inspector ID
  assignedAt            DateTime?
  
  // Inspection Details
  confirmedIssueType    String?               // Actual issue found: INTERNAL, MAINLINE, LEAKAGE, METER_DAMAGE, ILLEGAL_CONNECTION, OTHER
  estimatedMaterials    String?
  inspectionNotes       String?
  inspectionPhotos      String?
  
  // Repair Details
  repairDate            DateTime?
  repairNotes           String?
  completionPhoto       String?
  resolvedAt            DateTime?
  resolvedBy            String?
  
  // Issue Classification (Admin)
  issueTag              String?               // MINOR_LEAK, MAJOR_LINE_BREAK, ILLEGAL_CONNECTION, UPGRADE_REQUIRED
  
  // Status and Processing
  status                WaterIssueStatus      @default(PENDING_INSPECTION)
  remarks               String?
  processedBy           String?
  processedAt           DateTime?
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([issueType])
  @@index([createdAt])
}

enum WaterIssueType {
  NO_WATER
  LOW_PRESSURE
  PIPE_LEAK
  SERVICE_INTERRUPTION
  METER_PROBLEM
  OTHER
}

enum WaterIssueStatus {
  PENDING_INSPECTION
  FOR_SITE_INSPECTION
  RESOLVED_DUPLICATE
  FOR_REPAIR
  FOR_SCHEDULING
  AWAITING_PARTS
  REPAIR_IN_PROGRESS
  RESOLVED
  CANNOT_REPAIR
  CLOSED
}

// ========================================
// ASSET INVENTORY & WAREHOUSE MANAGEMENT
// ========================================

model InventoryItem {
  id                String              @id @default(uuid())
  itemCode          String              @unique       // System-generated identifier
  name              String
  description       String?
  category          InventoryCategory   @default(SUPPLIES)
  unit              String                            // e.g., "pcs", "box", "kg", "roll"
  
  // Stock tracking
  currentStock      Int                 @default(0)
  reservedStock     Int                 @default(0)   // Tagged for pending issuance
  reorderLevel      Int                 @default(0)   // Minimum stock before alert
  
  // Storage location
  storageZone       String?                           // e.g., "Zone A", "Rack 1"
  storageRack       String?                           // e.g., "Shelf 3"
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  // Relations
  deliveryItems     DeliveryItem[]
  requisitionItems  RequisitionItem[]
  stockAdjustments  StockAdjustment[]
  
  @@index([itemCode])
  @@index([category])
  @@index([name])
}

enum InventoryCategory {
  SUPPLIES
  MATERIALS
  EQUIPMENT
  TOOLS
  FURNITURE
  IT_EQUIPMENT
  CHEMICALS
  OTHER
}

model Delivery {
  id                String            @id @default(uuid())
  deliveryNumber    String            @unique         // System-generated
  
  // Supplier info
  supplierName      String
  supplierContact   String?
  supplierAddress   String?
  
  // Documents
  purchaseOrderNumber String
  purchaseOrderFile   String?                         // Uploaded PO document
  deliveryReceiptNumber String?
  deliveryReceiptFile   String?                       // Uploaded DR document
  noticeOfDelivery    String?                         // Uploaded NOD if applicable
  
  // Delivery details
  deliveryDate      DateTime          @default(now())
  receivedBy        String                            // Staff ID who received
  receivedByName    String?
  remarks           String?
  
  // Status flow: PENDING_VERIFICATION → VERIFIED → STORED
  status            DeliveryStatus    @default(PENDING_VERIFICATION)
  verifiedBy        String?                           // Staff who verified
  verifiedAt        DateTime?
  storedAt          DateTime?
  
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  
  // Relations
  items             DeliveryItem[]
  
  @@index([deliveryNumber])
  @@index([status])
  @@index([createdAt])
}

enum DeliveryStatus {
  PENDING_VERIFICATION
  VERIFIED
  STORED
}

model DeliveryItem {
  id              String          @id @default(uuid())
  deliveryId      String
  delivery        Delivery        @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  itemId          String?
  item            InventoryItem?  @relation(fields: [itemId], references: [id])
  
  itemName        String                              // Name (in case item not yet in system)
  description     String?
  quantity        Int
  unit            String
  verifiedQty     Int?                                // Actual qty after verification
  remarks         String?
  
  createdAt       DateTime        @default(now())
  
  @@index([deliveryId])
  @@index([itemId])
}

model Requisition {
  id                  String              @id @default(uuid())
  risNumber           String              @unique     // Requisition and Issue Slip number
  
  // Requesting party
  requestingOffice    String                          // Department / Office name
  requestedBy         String                          // Staff name
  requestedById       String?                         // User ID if in system
  purpose             String
  
  // Approval
  approvedBy          String?                         // Warehouse Officer ID
  approvedByName      String?
  approvedAt          DateTime?
  rejectionReason     String?
  
  // Issuance
  issuedBy            String?                         // Staff who prepared/released
  issuedByName        String?
  issuedAt            DateTime?
  acknowledgement     String?                         // Digital signature / acknowledgement note
  acknowledgementFile String?                         // Uploaded signed acknowledgement
  
  // Status: PENDING_APPROVAL → APPROVED / REJECTED / PENDING_STOCK → FOR_RELEASE → ISSUED
  status              RequisitionStatus   @default(PENDING_APPROVAL)
  remarks             String?
  
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  
  // Relations
  items               RequisitionItem[]
  
  @@index([risNumber])
  @@index([status])
  @@index([requestingOffice])
  @@index([createdAt])
}

enum RequisitionStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PENDING_STOCK
  FOR_RELEASE
  ISSUED
}

model RequisitionItem {
  id              String          @id @default(uuid())
  requisitionId   String
  requisition     Requisition     @relation(fields: [requisitionId], references: [id], onDelete: Cascade)
  itemId          String
  item            InventoryItem   @relation(fields: [itemId], references: [id])
  
  requestedQty    Int
  approvedQty     Int?                                // May differ from requested
  issuedQty       Int?                                // Actual issued
  remarks         String?
  
  createdAt       DateTime        @default(now())
  
  @@index([requisitionId])
  @@index([itemId])
}

model StockAdjustment {
  id              String              @id @default(uuid())
  itemId          String
  item            InventoryItem       @relation(fields: [itemId], references: [id])
  
  adjustmentType  StockAdjustmentType
  previousQty     Int
  newQty          Int
  difference      Int                                 // Can be negative
  reason          String
  
  performedBy     String                              // Staff ID
  performedByName String?
  
  createdAt       DateTime            @default(now())
  
  @@index([itemId])
  @@index([adjustmentType])
  @@index([createdAt])
}

enum StockAdjustmentType {
  PHYSICAL_COUNT
  CORRECTION
  DAMAGE
  LOSS
  RETURN
  INITIAL_STOCK
}

model InventoryReport {
  id              String            @id @default(uuid())
  reportType      ReportType
  reportPeriod    String                              // e.g., "Week 6 2026", "January 2026", "Q1 2026"
  periodStart     DateTime
  periodEnd       DateTime
  
  // Report data stored as JSON
  data            String                              // JSON with report details
  
  generatedBy     String                              // Staff ID
  generatedByName String?
  submittedTo     String?                             // e.g., "City Accounting Office", "COA"
  submittedAt     DateTime?
  
  notes           String?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([reportType])
  @@index([createdAt])
}

enum ReportType {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
}

