// SUB MODULE 1: Water Park Amenity Reservation
model AmenityReservation {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id])
  
  requesterName     String
  contactNumber     String
  preferredDate     DateTime
  preferredTime     String                              // e.g., "09:00 AM - 12:00 PM"
  numberOfGuests    Int
  amenityType       AmenityType
  amenityDetails    String?                             // specific cottage/table name
  
  proofOfResidency  String?                             // file path
  specialRequests   String?
  
  // Payment
  paymentStatus     PaymentType         @default(UNPAID)
  paymentMethod     String?                             // GCash / Onsite / Manual Override
  paymentReference  String?
  paymentProof      String?                             // file path
  amountDue         Float?
  amountPaid        Float?
  exemptionMemo     String?                             // file path for LGU-sponsored events
  
  // Processing
  status            ReservationStatus   @default(PENDING_REVIEW)
  remarks           String?
  processedBy       String?
  processedAt       DateTime?
  
  // Entry Pass / QR
  entryPassCode     String?             @unique
  entryPassUsed     Boolean             @default(false)
  checkedInAt       DateTime?
  checkedInBy       String?
  noShow            Boolean             @default(false)
  
  // Auto-cancel tracking
  holdExpiresAt     DateTime?                           // 24hr hold
  autoCancelled     Boolean             @default(false)
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([preferredDate])
  @@index([amenityType])
  @@index([entryPassCode])
}

enum AmenityType {
  SWIMMING_ENTRANCE
  COTTAGE
  TABLE
  ROOM
  OTHER
}

enum ReservationStatus {
  PENDING_REVIEW
  AWAITING_PAYMENT
  PAYMENT_VERIFIED
  APPROVED
  REJECTED
  CANCELLED
  CHECKED_IN
  NO_SHOW
  COMPLETED
}

enum PaymentType {
  UNPAID
  AWAITING_PAYMENT
  PAID
  VERIFIED
  EXEMPTED
}

// SUB MODULE 2: Venue Rental
model VenueBooking {
  id                  String            @id @default(uuid())
  userId              String
  user                User              @relation(fields: [userId], references: [id])
  
  applicantName       String
  organizationName    String?
  eventType           EventType
  eventTypeOther      String?                           // if EventType = OTHER
  
  venueType           VenueType
  venueDetails        String?                           // specific venue name
  
  desiredStartDate    DateTime
  desiredEndDate      DateTime
  estimatedAttendees  Int
  
  layoutFile          String?                           // file upload path
  contactPerson       String
  contactNumber       String
  
  // Permits / endorsements
