  barangayEndorsement String?                           // file path
  
  // Payment
  paymentStatus       PaymentType       @default(UNPAID)
  paymentMethod       String?
  paymentReference    String?
  paymentProof        String?
  amountDue           Float?
  amountPaid          Float?
  exemptionMemo       String?                           // file path for LGU waiver
  
  // Processing
  status              VenueBookingStatus @default(PENDING_REVIEW)
  remarks             String?
  processedBy         String?
  processedAt         DateTime?
  
