  additionalBilling   Float?
  
  // Auto-cancel & holds
  holdExpiresAt       DateTime?
  autoCancelled       Boolean                   @default(false)
  
  // LGU / Priority flags
  isLguEvent          Boolean                   @default(false)
  isPriority          Boolean                   @default(false)
  isPaymentExempted   Boolean                   @default(false)
  
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([desiredStartDate])
  @@index([facilityType])
  @@index([gatePassCode])
  @@index([createdAt])
}

enum FacilityActivityType {
